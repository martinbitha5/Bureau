# ─────────────────────────────────────────────────────────────
# Sensei — Variables d'environnement (modèle).
# Copier en `.env` et remplir. NE JAMAIS committer `.env`.
# Référence : docs/INTEGRATIONS.md
# ─────────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # serveur / Edge Functions UNIQUEMENT

# Paiement (mobile money / agrégateur) — voir INTEGRATIONS.md §3
PAYMENTS_PROVIDER=mock
PAYMENTS_API_KEY=
