# Inventaire vols — voir INTEGRATIONS.md §5
FLIGHTS_PROVIDER=mock
FLIGHTS_API_KEY=

# SMS / OTP — voir INTEGRATIONS.md §6
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=SENSEI
