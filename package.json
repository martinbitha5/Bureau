{
  "name": "sensei-group",
  "version": "0.0.0",
  "private": true,
  "description": "Sensei — écosystème de crédit RDC : bureau de crédit, BNPL, vente de billets d'avion.",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:start": "pnpm dlx supabase start",
    "db:stop": "pnpm dlx supabase stop",
    "db:reset": "pnpm dlx supabase db reset",
    "db:push": "pnpm dlx supabase db push",
    "db:types": "pnpm dlx supabase gen types typescript --local > packages/database/src/database.types.ts"
  },
  "devDependencies": {
    "pg": "^8.21.0",
    "turbo": "^2.5.0",
    "typescript": "^5.6.0"
  }
}
